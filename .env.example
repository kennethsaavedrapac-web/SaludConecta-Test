# Variables de Entorno - Salud-Conecta IA
# Copia este archivo como .env y completa los valores

# --- SUPABASE ---
# URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# Anon key pública de Supabase (segura para frontend)
VITE_SUPABASE_ANON_KEY=tu_clave_anonima_aqui

# --- GROQ AI ---
# API Key de Groq Cloud
GROQ_API_KEY=tu_groq_api_key_aqui

# --- WEB PUSH (Service Worker Notifications) ---
# Clave pública VAPID para notificaciones push
VITE_VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
# Clave privada VAPID (mantener en secreto en el servidor)
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui
# Email de contacto para VAPID
VAPID_SUBJECT=mailto:tu-email@ejemplo.com

# --- FRONTEND (CORS) ---
# URL del frontend para configurar CORS en las funciones de servidor
FRONTEND_URL=http://localhost:3000

# --- CRON (Opcional) ---
# Secreto para proteger las tareas programadas (cron jobs)
CRON_SECRET=tu_cron_secret_aqui

# --- GOOGLE MAPS ---
# API Key para Maps JavaScript API. Restringir por dominio en producción.
VITE_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# --- ENVIRONMENT ---
# Define el entorno de ejecución (development o production)
NODE_ENV=development
